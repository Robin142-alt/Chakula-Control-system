{
  "name": "chakula-control-system",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "node server/index.js",
    "dev:web": "node ./node_modules/vite/bin/vite.js --host 0.0.0.0",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "start": "node server/index.js",
    "start:demo": "node scripts/start-demo.js",
    "test": "node --test tests/**/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage tests/**/*.test.js",
    "smoke:prod": "node scripts/smoke-prod.js",
    "db:migrate": "node scripts/run-sql.js db/schema.sql",
    "db:seed": "node scripts/seed-demo.js",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "demo:screenshots": "node scripts/capture-screenshots.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "idb": "^8.0.2",
    "pg": "^8.13.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "playwright": "^1.54.2",
    "vite": "^5.4.11"
  }
}
